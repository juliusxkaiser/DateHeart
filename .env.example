# Server-side only. Set in Vercel/Netlify project settings, never expose it in client code.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Optional: enable Stripe Tax in Checkout after Stripe Tax is configured in your Stripe account.
STRIPE_AUTOMATIC_TAX=false

# Optional for cross-origin static hosts such as GitHub Pages using an external payment backend.
# Comma-separated list, for example: https://yourname.github.io,https://dateheart.example
PAYMENT_ALLOWED_ORIGINS=

# Optional client overrides when the app is hosted separately from the payment functions.
VITE_CHECKOUT_ENDPOINT=
VITE_VERIFY_PAYMENT_ENDPOINT=
VITE_RESTORE_PAYMENT_ENDPOINT=

# Optional public share URL. The app appends idea/lang/filter query params for deep links.
# Replace with App Store/Play Store URL when native apps are live.
VITE_APP_SHARE_URL=https://juliuskaiser.app/dateheart/

# Optional native AdMob overrides. Production banner and interstitial IDs are in src/ads.ts.
# Set VITE_ADMOB_TEST_MODE=true for local validation so real ads are not clicked.
# The android:debug and ios:build scripts enable test mode automatically.
VITE_ADMOB_ANDROID_BANNER_ID=
VITE_ADMOB_IOS_BANNER_ID=
VITE_ADMOB_ANDROID_INTERSTITIAL_ID=
VITE_ADMOB_IOS_INTERSTITIAL_ID=
VITE_ADMOB_TEST_MODE=
VITE_ADMOB_TEST_DEVICE_IDS=
VITE_ADMOB_CONSENT_DEBUG_GEOGRAPHY=
VITE_ADMOB_NON_PERSONALIZED=true
VITE_ENABLE_WEB_AD_PLACEHOLDER=false

# Debug-only helper for simulator/emulator billing checks before App Store Connect / Play Console products are live.
# The app only honors this together with VITE_ADMOB_TEST_MODE=true. Never enable it for release builds.
VITE_ENABLE_LOCAL_PURCHASE_TESTING=false

# Native App Store / Google Play Billing product IDs.
# These IDs must exist in App Store Connect and Play Console.
VITE_IAP_NO_ADS_PRODUCT_ID=dateheart_no_ads
VITE_IAP_PRO_MONTHLY_PRODUCT_ID=dateheart_pro_monthly
VITE_IAP_PRO_YEARLY_PRODUCT_ID=dateheart_pro_yearly

# Smoke-test helpers.
API_BASE_URL=
REQUIRE_CONFIGURED_PAYMENT=false

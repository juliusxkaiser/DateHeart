# Server-side only. Set in Vercel/Netlify project settings, never expose it in client code.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Optional: enable Stripe Tax in Checkout after Stripe Tax is configured in your Stripe account.
STRIPE_AUTOMATIC_TAX=false

# Optional for cross-origin static hosts such as GitHub Pages using an external payment backend.
# Comma-separated list, for example: https://yourname.github.io,https://dateheart.example
PAYMENT_ALLOWED_ORIGINS=

# Optional client overrides when the app is hosted separately from the payment functions.
VITE_CHECKOUT_ENDPOINT=
VITE_VERIFY_PAYMENT_ENDPOINT=
VITE_RESTORE_PAYMENT_ENDPOINT=

# Optional public share URL. Replace with App Store/Play Store URL when native apps are live.
VITE_APP_SHARE_URL=https://czarletsgo.github.io/dateheart-web/

# Smoke-test helpers.
API_BASE_URL=
REQUIRE_CONFIGURED_PAYMENT=false
